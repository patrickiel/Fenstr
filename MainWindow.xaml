<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Fenstr.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Fenstr"
    Title="Fenstr Settings">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" />

        <TextBlock Text="Settings" VerticalAlignment="Center" Margin="16,0,0,0"
                   Style="{StaticResource TitleTextBlockStyle}" IsHitTestVisible="False" />

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16,0,16,16" Spacing="4">

                <InfoBar x:Name="UpdateInfoBar"
                         Title="Update available"
                         IsOpen="False" IsClosable="True" Severity="Informational"
                         Margin="0,0,0,8">
                    <InfoBar.ActionButton>
                        <Button Content="Update now" Click="UpdateNow_Click" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <!-- General -->
                <TextBlock Text="General" Margin="4,0,0,8"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,8,16,8">
                    <StackPanel Spacing="4">
                        <ToggleSwitch x:Name="StartupToggle" Header="Run at login"
                                      Toggled="StartupToggle_Toggled" />
                        <ToggleSwitch x:Name="MaximizeFullScreenToggle"
                                      Header="Maximize when snapped region fills the screen"
                                      Toggled="MaximizeFullScreenToggle_Toggled" />
                        <ToggleSwitch x:Name="AutoUpdateToggle"
                                      Header="Check for updates automatically"
                                      Toggled="AutoUpdateToggle_Toggled" />
                    </StackPanel>
                </Border>

                <!-- Drag to maximize -->
                <TextBlock Text="Drag to maximize" Margin="4,16,0,8"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <ToggleSwitch x:Name="MaximizeDragToggle"
                                      Header="Enable drag to maximize"
                                      Toggled="MaximizeDragToggle_Toggled" />

                        <StackPanel x:Name="MaximizeWidthPanel" Spacing="4">
                            <TextBlock Text="Drop zone width (% of region)"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Slider x:Name="MaximizeWidthSlider" Minimum="10" Maximum="90"
                                        Width="260" ValueChanged="MaximizeWidthSlider_ValueChanged" />
                                <TextBlock x:Name="MaximizeWidthLabel" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Keyboard placement mode -->
                <TextBlock Text="Keyboard placement mode" Margin="4,16,0,8"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <ToggleSwitch x:Name="PlacementEnabledToggle"
                                      Header="Enable keyboard placement mode"
                                      Toggled="PlacementEnabledToggle_Toggled" />

                        <TextBlock Text="Press to enter placement mode"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <StackPanel x:Name="HotkeyPanel" Orientation="Horizontal" Spacing="8">
                            <ToggleButton x:Name="WinToggle" Content="Win" MinWidth="56"
                                          Checked="HotkeyChanged" Unchecked="HotkeyChanged" />
                            <ToggleButton x:Name="CtrlToggle" Content="Ctrl" MinWidth="56"
                                          Checked="HotkeyChanged" Unchecked="HotkeyChanged" />
                            <ToggleButton x:Name="AltToggle" Content="Alt" MinWidth="56"
                                          Checked="HotkeyChanged" Unchecked="HotkeyChanged" />
                            <ToggleButton x:Name="ShiftToggle" Content="Shift" MinWidth="56"
                                          Checked="HotkeyChanged" Unchecked="HotkeyChanged" />
                            <TextBlock Text="+" VerticalAlignment="Center" Margin="4,0"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button x:Name="KeyButton" MinWidth="80" Click="KeyButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Padding="16">
            <Button Content="Close" Style="{StaticResource AccentButtonStyle}" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
