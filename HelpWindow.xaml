<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Fenstr.HelpWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Fenstr"
    Title="Fenstr Help">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" />

        <TextBlock Text="Help" VerticalAlignment="Center" Margin="16,0,0,0"
                   Style="{StaticResource TitleTextBlockStyle}" IsHitTestVisible="False" />

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16,0,16,16" Spacing="4">

                <!-- Overview -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,4">
                    <TextBlock TextWrapping="Wrap"
                               Text="Fenstr snaps windows into custom regions on each monitor, using your mouse or keyboard." />
                </Border>

                <!-- Drag with the mouse -->
                <TextBlock Text="Drag with the mouse" Margin="4,16,0,8"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock TextWrapping="Wrap" Text="•  Drag any window toward a screen edge; a region overlay appears." />
                        <TextBlock TextWrapping="Wrap" Text="•  Release inside a region to snap the window there." />
                        <TextBlock TextWrapping="Wrap" Text="•  While dragging, scroll the mouse wheel to divide the monitor into 1–10 regions." />
                        <TextBlock TextWrapping="Wrap" Text="•  Hold Shift (or right-click-drag) across regions to span several regions into one zone." />
                    </StackPanel>
                </Border>

                <!-- Keyboard placement mode -->
                <TextBlock Text="Keyboard placement mode" Margin="4,16,0,8"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock TextWrapping="Wrap" Text="•  Press the placement hotkey (default: Win+Ctrl+Space) to enter placement mode." />
                        <TextBlock TextWrapping="Wrap" Text="•  Letters appear over each region. Type A–Z, 0–9, or F1–F12 to snap the active window there." />
                        <TextBlock TextWrapping="Wrap" Text="•  Press multiple letters quickly to span several regions." />
                        <TextBlock TextWrapping="Wrap" Text="•  Press Delete while a region letter is shown to clear that assignment." />
                        <TextBlock TextWrapping="Wrap" Text="•  Press Esc to cancel placement mode." />
                    </StackPanel>
                </Border>

                <!-- Win+Arrow shortcuts -->
                <TextBlock Text="Win+Arrow shortcuts" Margin="4,16,0,8"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <TextBlock TextWrapping="Wrap"
                               Text="Win+Left and Win+Right move the active window between regions on the current monitor." />
                </Border>

                <!-- Settings -->
                <TextBlock Text="Settings" Margin="4,16,0,8"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <TextBlock TextWrapping="Wrap"
                               Text="Open Settings from the tray icon to toggle Run at login and customize the placement-mode hotkey." />
                </Border>

                <!-- Windows Snap Layouts -->
                <TextBlock Text="About Windows Snap Layouts" Margin="4,16,0,8"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <TextBlock TextWrapping="Wrap"
                               Text="Fenstr automatically disables Windows 11's built-in Snap Layouts while it runs, and restores them when it exits." />
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Padding="16">
            <Button Content="Close" Style="{StaticResource AccentButtonStyle}" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
